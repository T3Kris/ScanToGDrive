# ───────────── Google Cloud & Service Account ─────────────
# Service account credentials. One of:
#   - path to the JSON key file (e.g. ./service-account.json)
#   - the raw JSON contents
#   - base64-encoded JSON (recommended for env vars / DigitalOcean secrets)
GOOGLE_SERVICE_ACCOUNT_JSON=
# A Workspace super-admin to impersonate for Admin SDK (group membership lookups).
GOOGLE_ADMIN_EMAIL=admin@yourdomain.com

# ───────────── Monitoring Configuration ─────────────
# Only emails from this sender are processed.
MONITOR_SENDER_EMAIL=sender@example.com
# Only members of this Google Group are monitored.
MONITOR_GROUP_EMAIL=group@yourdomain.com

# ───────────── Gmail API ─────────────
GMAIL_POLLING_INTERVAL_SECONDS=60
GMAIL_BATCH_SIZE=10
# How long to cache group membership before re-querying the Admin SDK.
GROUP_CACHE_TTL_SECONDS=300

# ───────────── Google Drive ─────────────
DRIVE_FOLDER_NAME=Email Attachments
DRIVE_MAX_FILE_SIZE_BYTES=104857600

# ───────────── Application ─────────────
NODE_ENV=production
PORT=8080
LOG_LEVEL=info
LOG_BUFFER_SIZE=1000
# Where restart-recovery state is persisted (last processed ids, pause flag).
STATE_FILE_PATH=./data/state.json

# ───────────── Dashboard Auth ─────────────
# Shared secret protecting the dashboard + API. Strongly recommended.
# If unset, the dashboard is open (only acceptable behind a trusted network).
DASHBOARD_API_KEY=
